{
  "expo": {
    "name": "my-llm",
    "slug": "my-llm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "이미지를 선택하여 AI에게 질문할 수 있습니다."
      },
      "bundleIdentifier": "com.mrtint.myllm"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.mrtint.myllm"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "targetSdkVersion": 34,
            "extraMavenRepos": [
              "https://jitpack.io"
            ]
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "llama.rn"
    ]
  }
}
